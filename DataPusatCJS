<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Unggah Dokumen - PT Cipta Jasa Selaras</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1a1a2e;
            --accent: #c0963c;
            --bg: #faf9f6;
            --white: #ffffff;
            --text: #3d3d5c;
            --border: #e4e0d8;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            background: var(--white);
            max-width: 500px;
            width: 100%;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            border: 1px solid var(--border);
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 24px;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .header p {
            font-size: 14px;
            color: #7a7a9a;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--primary);
        }

        select, input[type="file"] {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            background: #fdfbf7;
        }

        .btn-submit {
            width: 100%;
            background: var(--accent);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background: #a67f32;
            transform: translateY(-2px);
        }

        .footer-note {
            margin-top: 25px;
            font-size: 12px;
            text-align: center;
            color: #999;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>Portal Satu Gerbang</h1>
        <p>Unggah dokumen ke repositori Google Drive</p>
    </div>

    <form id="uploadForm">
        <div class="form-group">
            <label for="category">Kategori Dokumen</label>
            <select id="category" name="category" required>
                <option value="" disabled selected>Pilih Kategori...</option>
                <option value="Penawaran">Dokumen Penawaran</option>
                <option value="Arsip_SPK">Arsip SPK</option>
                <option value="Kwitansi">Kwitansi / Invoice</option>
                <option value="Perpajakan">Dokumen Perpajakan</option>
                <option value="SDM">Data Tenaga Kerja</option>
            </select>
        </div>

        <div class="form-group">
            <label for="file">Pilih Berkas</label>
            <input type="file" id="file" name="file" required>
        </div>

        <button type="submit" class="btn-submit">Unggah Sekarang</button>
    </form>

    <div class="footer-note">
        PT Cipta Jasa Selaras - Administrasi Terpusat
    </div>
</div>

<script>
    /**
     * Catatan Teknis:
     * Untuk menghubungkan ini ke Google Drive tanpa server rumit, 
     * gunakan Google Apps Script sebagai backend (Web App).
     */
    const form = document.getElementById('uploadForm');
    
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const fileInput = document.getElementById('file');
        const category = document.getElementById('category').value;
        const file = fileInput.files[0];
        
        if (!file) return;

        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = function() {
            const rawLog = reader.result.split(',')[1];
            
            // Tampilkan loading (visual sederhana)
            const btn = document.querySelector('.btn-submit');
            btn.innerText = 'Sedang Mengunggah...';
            btn.disabled = true;

            // URL ini didapatkan setelah Deploy Google Apps Script
            const script_url = "https://script.google.com/macros/s/AKfycbwl1nlfsbzBuug-_0tRtF0Le55SHGiyuA0yY7QTx45F1fMwEHUfJYjnX9iv8M4a0Kqg/exec"; 

            fetch(script_url, {
                method: "POST",
                body: JSON.stringify({
                    "data": rawLog,
                    "mimetype": file.type,
                    "filename": file.name,
                    "category": category
                })
            })
            .then(res => res.json())
            .then(data => {
                alert("Berhasil! Dokumen diunggah ke folder: " + category);
                form.reset();
            })
            .catch(err => {
                console.log(err);
                alert("Terjadi kesalahan. Pastikan URL Apps Script sudah benar.");
            })
            .finally(() => {
                btn.innerText = 'Unggah Sekarang';
                btn.disabled = false;
            });
        };
    });
</script>

</body>
</html>